# =============================================================================
# LLM 摘要配置
# =============================================================================

# LLM 服务商配置
# 可选值：zhipu / gemini / none
# zhipu：使用智谱模型生成报告；gemini：使用 Gemini 模型生成报告；none：关闭 LLM，使用本地 Markdown 模板兜底
LLM_PROVIDER=zhipu

# 智谱 API Key
# 当 LLM_PROVIDER=zhipu 时填写；不要提交真实密钥到仓库
ZHIPU_API_KEY=

# Gemini API Key
# 当 LLM_PROVIDER=gemini 时填写；不要提交真实密钥到仓库
GEMINI_API_KEY=

# 通用 LLM API Key
# 可选；如果填写，会优先于 ZHIPU_API_KEY / GEMINI_API_KEY
LLM_API_KEY=

# LLM 模型名称
# 可选；不填写时使用 config/settings.toml 中的默认模型
# 智谱默认：glm-4-flash；Gemini 默认：gemini-2.5-flash
LLM_MODEL=

# LLM 请求超时时间，单位：秒
# 可选；不填写时默认 120 秒
LLM_TIMEOUT_SECONDS=120


# =============================================================================
# 运行日志配置
# =============================================================================

# 日志级别
# 可选值：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 日志格式
# 可选值：json / text
LOG_FORMAT=json


# =============================================================================
# 订阅调度配置
# =============================================================================

# 是否启用订阅定时调度器
# true：应用启动后按订阅间隔自动抓取；false：仅支持手动触发
SCHEDULER_ENABLED=true

# 调度器扫描间隔，单位：秒
# 表示每隔多久检查一次是否存在到期订阅
SCHEDULER_TICK_SECONDS=30


# =============================================================================
# 通知 Worker 配置
# =============================================================================

# 是否启用应用内通知 Worker。
# true：应用启动后会扫描 notification_jobs 并执行真实通知发送。
# false：只创建通知任务，不发送邮件、企业微信或 Webhook。
NOTIFICATION_WORKER_ENABLED=false

# 通知 Worker 扫描间隔，单位：秒。
# 例如 30 表示每 30 秒检查一次是否有 pending 状态的通知任务。
NOTIFICATION_WORKER_TICK_SECONDS=30


# =============================================================================
# SMTP 邮箱通知配置
# =============================================================================

# 163 邮箱示例：HOST=smtp.163.com，PORT=587，USERNAME/FROM_EMAIL=你的完整 163 邮箱，PASSWORD=通用授权码

# SMTP 服务器地址。
# 163 邮箱使用 smtp.163.com。
NOTIFICATION_SMTP_HOST=smtp.163.com

# SMTP 服务器端口。
# 587 通常配合 STARTTLS；465 通常配合 SSL 直连。
NOTIFICATION_SMTP_PORT=587

# SMTP 登录账号。
# 163 邮箱需要填写完整邮箱地址。
NOTIFICATION_SMTP_USERNAME=

# SMTP 登录密码。
# 163 邮箱这里填写“通用授权码”，不要填写网页登录密码。
NOTIFICATION_SMTP_PASSWORD=

# 发件人邮箱。
# 通常与 NOTIFICATION_SMTP_USERNAME 保持一致。
NOTIFICATION_SMTP_FROM_EMAIL=

# 是否使用 STARTTLS 加密连接。
# 587 端口通常设为 true。
NOTIFICATION_SMTP_USE_TLS=true

# 是否使用 SSL 直连。
# 465 端口通常设为 true；使用 587 STARTTLS 时保持 false。
NOTIFICATION_SMTP_USE_SSL=false


# =============================================================================
# 企业微信自建应用通知配置
# =============================================================================

# 企业微信企业 ID，可在企业微信管理后台「我的企业」中查看。
# 仅 channel_type=wecom 的通知会使用；属于敏感信息，不要提交真实值。
NOTIFICATION_WECOM_CORP_ID=

# 企业微信自建应用 AgentId，可在「应用管理」对应自建应用详情中查看。
NOTIFICATION_WECOM_AGENT_ID=

# 企业微信自建应用 Secret，可在「应用管理」对应自建应用详情中查看。
# 该应用的可见范围必须包含接收人账号。
NOTIFICATION_WECOM_SECRET=

# 默认接收人账号/UserID。
# 创建订阅时选择「企业微信」并填写通知目标时，优先使用订阅里的通知目标；这里作为兜底值。
# 多个账号使用 | 分隔，例如 zhangsan|lisi；全部可见成员可填 @all。
NOTIFICATION_WECOM_TO_USER=

# 企业微信接收消息服务器 URL。
# 后续部署到服务器并实现回调验证接口后填写，例如 https://your-domain.com/wecom/callback。
NOTIFICATION_WECOM_CALLBACK_URL=

# 企业微信接收消息服务器 Token。
# 与企业微信后台「API接收消息」页面填写的 Token 保持一致。
NOTIFICATION_WECOM_CALLBACK_TOKEN=

# 企业微信接收消息服务器 EncodingAESKey。
# 与企业微信后台「API接收消息」页面填写的 EncodingAESKey 保持一致。
NOTIFICATION_WECOM_CALLBACK_ENCODING_AES_KEY=


# =============================================================================
# 通用 Webhook 通知配置
# =============================================================================

# 通用 Webhook URL。
# 仅 channel_type=webhook 的通知会使用，用于对接自有系统或第三方 HTTP 接口。
NOTIFICATION_WEBHOOK_URL=

# 通用 Webhook Bearer Token。
# 如果目标 Webhook 需要 Authorization 认证则填写，否则留空。
NOTIFICATION_WEBHOOK_TOKEN=

# 通知 HTTP 请求超时时间，单位：秒。
# 企业微信和 Webhook 发送请求超过该时间会判定失败。
NOTIFICATION_TIMEOUT_SECONDS=10


# =============================================================================
# 安全与数据存储配置
# =============================================================================

# 访问令牌加密密钥
# 可选但建议配置；用于稳定加密/解密订阅仓库时保存的 access_token
# 可使用 Fernet 密钥，例如通过 Python cryptography.fernet.Fernet.generate_key() 生成
TOKEN_ENCRYPTION_KEY=

# 数据库连接地址
# 可选；不填写时使用 config/settings.toml 中的 SQLite 默认配置
DATABASE_URL=sqlite+aiosqlite:///./github_sentinel.db
